{
  "expo": {
    "name": "TryOn",
    "slug": "tryon",
    "version": "1.0.11",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.evofaceflow.tryon.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TryOn uses your camera to photograph clothing items for virtual try-on. Clothing photos are processed by AI to generate images of you wearing them.",
        "NSPhotoLibraryUsageDescription": "TryOn uses your photo library to upload body and clothing photos. Body photos are processed by AI (xAI Grok) to generate try-on images. You can delete them at any time from Settings.",
        "NSPhotoLibraryAddUsageDescription": "TryOn saves your AI-generated try-on results to your photo library when you choose to.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tryon.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "tryon",
    "plugins": [
      "expo-secure-store",
      "expo-iap",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "TryOn uses your camera to photograph clothing items. Photos are processed by AI to generate try-on images."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TryOn uses your photo library to upload body and clothing photos. Body photos are processed by AI (xAI Grok) to generate try-on images."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "209e84f3-f3fa-458f-a26a-8b76023b2197"
      },
      "appleProducts": {
        "subscriptions": {
          "basicMonthly": "com.evofaceflow.tryon.app.basic.monthly",
          "premiumMonthly": "com.evofaceflow.tryon.app.premium.monthly"
        },
        "credits": {
          "FREE": {
            "10": "com.evofaceflow.tryon.app.credits.10.free",
            "25": "com.evofaceflow.tryon.app.credits.25.free",
            "50": "com.evofaceflow.tryon.app.credits.50.free",
            "100": "com.evofaceflow.tryon.app.credits.100.free"
          },
          "BASIC": {
            "10": "com.evofaceflow.tryon.app.credits.10.basic",
            "25": "com.evofaceflow.tryon.app.credits.25.basic.v2",
            "50": "com.evofaceflow.tryon.app.credits.50.basic",
            "100": "com.evofaceflow.tryon.app.credits.100.basic"
          },
          "PREMIUM": {
            "10": "com.evofaceflow.tryon.app.credits.10.premium",
            "25": "com.evofaceflow.tryon.app.credits.25.premium",
            "50": "com.evofaceflow.tryon.app.credits.50.premium",
            "100": "com.evofaceflow.tryon.app.credits.100.premium"
          }
        }
      }
    },
    "owner": "bruhnf"
  }
}
