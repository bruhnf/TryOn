{
  "expo": {
    "name": "TryOn",
    "slug": "tryon",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.evofaceflow.tryon.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TryOn uses your camera to photograph clothing items for virtual try-on. Clothing photos are processed by AI to generate images of you wearing them.",
        "NSPhotoLibraryUsageDescription": "TryOn uses your photo library to upload body and clothing photos. Body photos are processed by AI (xAI Grok) to generate try-on images. You can delete them at any time from Settings.",
        "NSPhotoLibraryAddUsageDescription": "TryOn saves your AI-generated try-on results to your photo library when you choose to.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tryon.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "tryon",
    "plugins": [
      "expo-secure-store",
      "expo-iap",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "TryOn uses your camera to photograph clothing items. Photos are processed by AI to generate try-on images."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TryOn uses your photo library to upload body and clothing photos. Body photos are processed by AI (xAI Grok) to generate try-on images."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "209e84f3-f3fa-458f-a26a-8b76023b2197"
      },
      "appleProducts": {
        "subscriptions": {
          "basicMonthly": "com.evofaceflow.tryon.app.basic.monthly",
          "premiumMonthly": "com.evofaceflow.tryon.app.premium.monthly"
        },
        "credits": {
          "10": "com.evofaceflow.tryon.app.credits.10",
          "25": "com.evofaceflow.tryon.app.credits.25",
          "50": "com.evofaceflow.tryon.app.credits.50",
          "100": "com.evofaceflow.tryon.app.credits.100"
        }
      },
      "appleProductReferenceIds": {
        "_comment": "App Store Connect internal UUIDs (NOT product IDs). Useful only for App Store Server API endpoints that target a specific product. Do not pass these to StoreKit.",
        "credits10": "621215711f318a4fc1813a7dff937ef2",
        "credits25": "4964e60bf506b1d82efe966ec71d1421",
        "credits50": "333424bfef0ca60466e258ffbe20ea90",
        "credits100": "47501df29b5777086fb59b628932368f",
        "basicTier": "9d99727cc5d1b37563ff2175d63880e9",
        "premiumTier": "ed387b679d97548b2ff33b5f20aee52a"
      }
    },
    "owner": "bruhnf"
  }
}
