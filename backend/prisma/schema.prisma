generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum CreditTransactionType {
  PURCHASE
  GRANT
  USAGE
  REFUND
}

enum UserTier {
  FREE
  BASIC
  PREMIUM
}

enum NotificationType {
  FOLLOW
  LIKE
  TRYON_COMPLETE
}

model User {
  id                String            @id @default(uuid())
  username          String            @unique
  email             String            @unique
  passwordHash      String
  verified          Boolean           @default(false)
  verifyToken       String?
  verifyTokenExpiry DateTime?
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  tier              UserTier          @default(FREE)
  credits           Int               @default(0)
  // Lifetime count of try-on sessions generated
  tryOnCount        Int               @default(0)
  // Tracks when this FREE-tier user last received the monthly free-credit grant
  lastFreeCreditGrantAt DateTime?
  firstName         String?
  lastName          String?
  bio               String?
  // avatarUrl = close-up photo — used for profile display ONLY, never sent to Grok
  avatarUrl         String?
  // fullBodyUrl and mediumBodyUrl are the inputs for the Grok try-on API
  fullBodyUrl       String?
  mediumBodyUrl     String?
  followingCount    Int               @default(0)
  followersCount    Int               @default(0)
  likesCount        Int               @default(0)
  address           String?
  city              String?
  state             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tryOnJobs          TryOnJob[]
  locations          UserLocation[]
  following          Follow[]            @relation("Follower")
  followers          Follow[]            @relation("Following")
  refreshTokens      RefreshToken[]
  creditTransactions CreditTransaction[]
  likes              Like[]
  notifications      Notification[]      @relation("NotificationRecipient")
  actorNotifications Notification[]      @relation("NotificationActor")
  applePurchases     ApplePurchase[]

  @@map("users")
}

// Records of Apple In-App Purchase / StoreKit subscription receipts.
// One row per StoreKit transaction; the `originalTransactionId` ties together
// renewals of the same subscription so we can resolve the active entitlement.
model ApplePurchase {
  id                    String   @id @default(uuid())
  userId                String
  // Apple StoreKit transaction identifier (unique per renewal/purchase).
  transactionId         String   @unique
  // Original transaction id — stable across renewals of the same subscription.
  originalTransactionId String
  // App Store product identifier (e.g. com.evofaceflow.tryon.basic.monthly).
  productId             String
  // Subscription tier this purchase grants on our side.
  tier                  UserTier
  // Subscription expiration date as reported by Apple (null for non-subscription IAPs).
  expiresAt             DateTime?
  // Raw signed receipt / JWS payload for audit + re-verification.
  rawReceipt            String?
  // Set when StoreKit reports the user revoked/refunded the purchase.
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([originalTransactionId])
  @@map("apple_purchases")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model TryOnJob {
  id                String    @id @default(uuid())
  userId            String
  status            JobStatus @default(PENDING)
  isPrivate         Boolean   @default(false)
  clothingPhoto1Url String
  clothingPhoto2Url String?
  resultFullBodyUrl String?
  resultMediumUrl   String?
  // primary body photo used as input (full body preferred, medium as fallback)
  bodyPhotoUrl      String?
  // which user body photo perspectives were used as inputs
  perspectivesUsed  String[]
  // denormalized like count for feed performance
  likesCount        Int       @default(0)
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes          Like[]
  notifications  Notification[]

  @@map("tryon_jobs")
}

model UserLocation {
  id                 String   @id @default(uuid())
  userId             String
  ip                 String
  country            String?
  region             String?
  city               String?
  latitude           Float?
  longitude          Float?
  timezone           String?
  trigger            String?
  suspiciousLocation Boolean  @default(false)
  distanceFromLast   Float?
  timestamp          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_locations")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  type        CreditTransactionType
  amount      Int                   // positive for grants/purchases, negative for usage
  description String?
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  TryOnJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
  @@map("likes")
}

model Notification {
  id          String           @id @default(uuid())
  // recipient of the notification
  userId      String
  type        NotificationType
  // user who triggered the notification (e.g., the follower or liker)
  actorId     String?
  // optional related try-on job (e.g., for LIKE or TRYON_COMPLETE)
  jobId       String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user  User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  job   TryOnJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("notifications")
}

enum ScanType {
  NPM_BACKEND
  NPM_FRONTEND
  SYSTEM_PACKAGES
  DOCKER_IMAGES
  SSL_CERTIFICATE
}

enum VulnerabilitySeverity {
  INFO
  LOW
  MODERATE
  HIGH
  CRITICAL
}

model VulnerabilityReport {
  id                 String                 @id @default(uuid())
  scanType           ScanType
  totalVulnerabilities Int                  @default(0)
  criticalCount      Int                    @default(0)
  highCount          Int                    @default(0)
  moderateCount      Int                    @default(0)
  lowCount           Int                    @default(0)
  infoCount          Int                    @default(0)
  details            String?                // JSON string with full audit report
  systemInfo         String?                // OS version, Docker version, etc.
  packagesChecked    Int?                   // Number of packages scanned
  fixAvailable       Boolean                @default(false)
  scanDurationMs     Int?                   // How long the scan took
  errorMessage       String?                // If scan failed
  createdAt          DateTime               @default(now())

  @@index([scanType, createdAt])
  @@map("vulnerability_reports")
}
