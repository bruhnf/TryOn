generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum CreditTransactionType {
  PURCHASE
  GRANT
  USAGE
  REFUND
}

model User {
  id                String            @id @default(uuid())
  username          String            @unique
  email             String            @unique
  passwordHash      String
  verified          Boolean           @default(false)
  verifyToken       String?
  verifyTokenExpiry DateTime?
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  // Subscription: true = active subscriber, false = free user
  isSubscribed      Boolean           @default(false)
  // Credits: bonus credits that can be used beyond daily limit
  credits           Int               @default(0)
  firstName         String?
  lastName          String?
  bio               String?
  // avatarUrl = close-up photo — used for profile display ONLY, never sent to Grok
  avatarUrl         String?
  // fullBodyUrl and mediumBodyUrl are the inputs for the Grok try-on API
  fullBodyUrl       String?
  mediumBodyUrl     String?
  followingCount    Int               @default(0)
  followersCount    Int               @default(0)
  likesCount        Int               @default(0)
  address           String?
  city              String?
  state             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tryOnJobs          TryOnJob[]
  locations          UserLocation[]
  following          Follow[]            @relation("Follower")
  followers          Follow[]            @relation("Following")
  refreshTokens      RefreshToken[]
  creditTransactions CreditTransaction[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model TryOnJob {
  id                String    @id @default(uuid())
  userId            String
  status            JobStatus @default(PENDING)
  isPrivate         Boolean   @default(false)
  clothingPhoto1Url String
  clothingPhoto2Url String?
  resultFullBodyUrl String?
  resultMediumUrl   String?
  // which user body photo perspectives were used as inputs
  perspectivesUsed  String[]
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tryon_jobs")
}

model UserLocation {
  id                 String   @id @default(uuid())
  userId             String
  ip                 String
  country            String?
  region             String?
  city               String?
  latitude           Float?
  longitude          Float?
  timezone           String?
  trigger            String?
  suspiciousLocation Boolean  @default(false)
  distanceFromLast   Float?
  timestamp          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_locations")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  type        CreditTransactionType
  amount      Int                   // positive for grants/purchases, negative for usage
  description String?
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

enum ScanType {
  NPM_BACKEND
  NPM_FRONTEND
  SYSTEM_PACKAGES
  DOCKER_IMAGES
  SSL_CERTIFICATE
}

enum VulnerabilitySeverity {
  INFO
  LOW
  MODERATE
  HIGH
  CRITICAL
}

model VulnerabilityReport {
  id                 String                 @id @default(uuid())
  scanType           ScanType
  totalVulnerabilities Int                  @default(0)
  criticalCount      Int                    @default(0)
  highCount          Int                    @default(0)
  moderateCount      Int                    @default(0)
  lowCount           Int                    @default(0)
  infoCount          Int                    @default(0)
  details            String?                // JSON string with full audit report
  systemInfo         String?                // OS version, Docker version, etc.
  packagesChecked    Int?                   // Number of packages scanned
  fixAvailable       Boolean                @default(false)
  scanDurationMs     Int?                   // How long the scan took
  errorMessage       String?                // If scan failed
  createdAt          DateTime               @default(now())

  @@index([scanType, createdAt])
  @@map("vulnerability_reports")
}
