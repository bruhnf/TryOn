generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum CreditTransactionType {
  PURCHASE
  GRANT
  USAGE
  REFUND
}

enum UserTier {
  FREE
  BASIC
  PREMIUM
}

enum NotificationType {
  FOLLOW
  LIKE
  TRYON_COMPLETE
  COMMENT
  COMMENT_REPLY
  COMMENT_LIKE
}

enum ReportTargetType {
  TRYON_JOB
  USER
  COMMENT
}

enum ReportReason {
  INAPPROPRIATE
  HARASSMENT
  IMPERSONATION
  SPAM
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED_REMOVED
  RESOLVED_NO_ACTION
}

model User {
  id                       String    @id @default(uuid())
  username                 String    @unique
  email                    String    @unique
  passwordHash             String
  verified                 Boolean   @default(false)
  verifyToken              String?
  verifyTokenExpiry        DateTime?
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  tier                     UserTier  @default(FREE)
  credits                  Int       @default(0)
  // Lifetime count of try-on sessions generated
  tryOnCount               Int       @default(0)
  // Set once at email verification when the one-time signup credit grant is
  // applied. Retained for audit; no longer drives any logic.
  lastFreeCreditGrantAt    DateTime?
  // Timestamp of the user's most recent explicit consent to send body +
  // clothing photos to xAI's Grok Imagine API. Null = no consent on file or
  // revoked. Required by App Store Review Guidelines 5.1.1(i) / 5.1.2(i):
  // the try-on submit endpoint refuses with AI_CONSENT_REQUIRED when null,
  // and the client surfaces an explicit opt-in dialog before re-submitting.
  aiProcessingConsentAt    DateTime?
  firstName                String?
  lastName                 String?
  bio                      String?
  // The *Url columns below store an S3 key (e.g. "body-photos/<userId>/<file>.jpg"),
  // not a public URL. The bucket is private; presigned GET URLs are minted at
  // response time by services/imageUrlService.ts. Legacy rows may still hold
  // full https://...amazonaws.com/... URLs — the presign helpers tolerate both.
  // avatarUrl = close-up photo — used for profile display ONLY, never sent to Grok
  avatarUrl                String?
  // fullBodyUrl and mediumBodyUrl are the inputs for the Grok try-on API
  fullBodyUrl              String?
  mediumBodyUrl            String?
  followingCount           Int       @default(0)
  followersCount           Int       @default(0)
  likesCount               Int       @default(0)
  address                  String?
  city                     String?
  state                    String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  tryOnJobs          TryOnJob[]
  locations          UserLocation[]
  following          Follow[]            @relation("Follower")
  followers          Follow[]            @relation("Following")
  refreshTokens      RefreshToken[]
  creditTransactions CreditTransaction[]
  likes              Like[]
  comments           Comment[]
  commentLikes       CommentLike[]
  notifications      Notification[]      @relation("NotificationRecipient")
  actorNotifications Notification[]      @relation("NotificationActor")
  applePurchases     ApplePurchase[]
  reportsFiled       Report[]            @relation("ReportReporter")
  blocking           UserBlock[]         @relation("BlockerUser")
  blockedBy          UserBlock[]         @relation("BlockedUser")

  @@map("users")
}

// User-submitted report of objectionable content or behavior.
// Required by App Store Review Guideline 1.2 for apps with UGC.
model Report {
  id           String           @id @default(uuid())
  reporterId   String
  targetType   ReportTargetType
  // ID of the reported entity (TryOnJob.id when targetType=TRYON_JOB, User.id when targetType=USER).
  targetId     String
  reason       ReportReason
  // Optional free-text from the reporter for additional context.
  details      String?
  status       ReportStatus     @default(OPEN)
  // Admin's note when resolving the report.
  resolverNote String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())

  reporter User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@map("reports")
}

// One row per "user A has blocked user B". Used to filter feeds and profile
// visibility in both directions: blocked users do not see the blocker's
// content either, to prevent retaliation discovery.
model UserBlock {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

// Records of Apple In-App Purchase / StoreKit subscription receipts.
// One row per StoreKit transaction; the `originalTransactionId` ties together
// renewals of the same subscription so we can resolve the active entitlement.
model ApplePurchase {
  id                    String    @id @default(uuid())
  userId                String
  // Apple StoreKit transaction identifier (unique per renewal/purchase).
  transactionId         String    @unique
  // Original transaction id — stable across renewals of the same subscription.
  originalTransactionId String
  // App Store product identifier (e.g. com.evofaceflow.tryon.basic.monthly).
  productId             String
  // Subscription tier this purchase grants on our side.
  tier                  UserTier
  // Subscription expiration date as reported by Apple (null for non-subscription IAPs).
  expiresAt             DateTime?
  // Raw signed receipt / JWS payload for audit + re-verification.
  rawReceipt            String?
  // Set when StoreKit reports the user revoked/refunded the purchase.
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([originalTransactionId])
  @@map("apple_purchases")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model TryOnJob {
  id                String    @id @default(uuid())
  userId            String
  status            JobStatus @default(PENDING)
  isPrivate         Boolean   @default(false)
  // The *Url columns below store an S3 key, not a public URL — the bucket is
  // private and presigned GET URLs are minted at response time by
  // services/imageUrlService.ts. Legacy rows may still hold full
  // https://...amazonaws.com/... URLs; the presign helpers tolerate both.
  clothingPhoto1Url String
  clothingPhoto2Url String?
  resultFullBodyUrl String?
  resultMediumUrl   String?
  // primary body photo used as input (full body preferred, medium as fallback)
  bodyPhotoUrl      String?
  // which user body photo perspectives were used as inputs
  perspectivesUsed  String[]
  // denormalized like count for feed performance
  likesCount        Int       @default(0)
  // denormalized comment count for feed performance
  commentsCount     Int       @default(0)
  // user's credit balance at the moment the try-on was submitted (before any deduction)
  creditsAtTime     Int?
  // When the worker is scheduled to actually start this job. Null = start
  // immediately. Non-null when the soft throttle deferred the submission so
  // the client can render a "starts in X:XX" countdown. The BullMQ delay is
  // the authoritative timer; this column is for client display only.
  scheduledStartAt  DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  notifications Notification[]

  @@map("tryon_jobs")
}

// User-authored comment on a TryOnJob. Comments are public when the parent
// TryOnJob is public; private TryOnJobs are not commentable from the feed.
// Authors can delete their own comment; the post owner can delete any
// comment on their own post. Other users can Report instead.
//
// Threading: single-level (Instagram/TikTok-style). A reply has parentId set
// to a top-level comment; replies cannot themselves have replies. Deleting a
// parent cascades to its replies via the FK ON DELETE CASCADE.
model Comment {
  id        String   @id @default(uuid())
  jobId     String
  userId    String
  body      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job           TryOnJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  likes         CommentLike[]
  notifications Notification[]

  @@index([jobId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

// One row per (user, comment) like. Unique constraint enforces idempotency
// — a second POST is a no-op rather than creating a duplicate.
model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

model UserLocation {
  id                 String   @id @default(uuid())
  userId             String
  ip                 String
  country            String?
  region             String?
  city               String?
  latitude           Float?
  longitude          Float?
  timezone           String?
  trigger            String?
  suspiciousLocation Boolean  @default(false)
  distanceFromLast   Float?
  timestamp          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_locations")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  type        CreditTransactionType
  amount      Int // positive for grants/purchases, negative for usage
  description String?
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  TryOnJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
  @@map("likes")
}

model Notification {
  id        String           @id @default(uuid())
  // recipient of the notification
  userId    String
  type      NotificationType
  // user who triggered the notification (e.g., the follower or liker)
  actorId   String?
  // optional related try-on job (e.g., for LIKE or TRYON_COMPLETE)
  jobId     String?
  // optional related comment — set for COMMENT_REPLY (the parent comment that
  // was replied to) and COMMENT_LIKE (the comment that was liked). Lets the
  // mobile app deep-link into the thread and auto-scroll to that comment.
  commentId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  job     TryOnJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  comment Comment?  @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("notifications")
}

enum ScanType {
  NPM_BACKEND
  NPM_FRONTEND
  SYSTEM_PACKAGES
  DOCKER_IMAGES
  SSL_CERTIFICATE
}

enum VulnerabilitySeverity {
  INFO
  LOW
  MODERATE
  HIGH
  CRITICAL
}

model VulnerabilityReport {
  id                   String   @id @default(uuid())
  scanType             ScanType
  totalVulnerabilities Int      @default(0)
  criticalCount        Int      @default(0)
  highCount            Int      @default(0)
  moderateCount        Int      @default(0)
  lowCount             Int      @default(0)
  infoCount            Int      @default(0)
  details              String? // JSON string with full audit report
  systemInfo           String? // OS version, Docker version, etc.
  packagesChecked      Int? // Number of packages scanned
  fixAvailable         Boolean  @default(false)
  scanDurationMs       Int? // How long the scan took
  errorMessage         String? // If scan failed
  createdAt            DateTime @default(now())

  @@index([scanType, createdAt])
  @@map("vulnerability_reports")
}
