# Database
DATABASE_URL="postgresql://tryon:tryon_dev@localhost:5432/tryon_db"

# JWT - generate with: openssl rand -hex 32
JWT_SECRET="replace_with_random_hex_32"
JWT_REFRESH_SECRET="replace_with_different_random_hex_32"

# App
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:8081,exp://localhost:8081"

# Admin
ADMIN_API_KEY="replace_with_secure_admin_key"

# AWS S3
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="tryon-media"

# Redis
REDIS_URL="redis://localhost:6379"

# xAI Grok
GROK_API_KEY="your_xai_api_key"
GROK_API_URL="https://api.x.ai/v1"

# Email (AWS SES)
SES_FROM_ADDRESS="noreply@evofaceflow.com"
SES_REGION="us-east-1"
# For dev: use Ethereal (https://ethereal.email) or Mailtrap
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# App URL (for email links)
APP_URL="https://evofaceflow.com"
FRONTEND_DEEP_LINK="tryon://"

# Geo-IP (optional - falls back to ip-api.com free tier)
GEOIP_API_KEY=""
