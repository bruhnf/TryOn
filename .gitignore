# ===========================================
# TryOn Monorepo .gitignore
# Backend: Node.js/Express + Prisma
# Frontend: React Native/Expo
# ===========================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/

# Environment files (keep .env.example tracked)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
backend/.env
frontend/.env

# Build outputs
dist/
build/
out/
*.tsbuildinfo
.next/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE/Editor
.idea/
*.swp
*.swo
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# OS files
.DS_Store
Thumbs.db
*.DS_Store
ehthumbs.db
Desktop.ini
._*

# ===========================================
# React Native / Expo
# ===========================================

# Expo local folders (device/user specific)
.expo/
.expo-shared/
frontend/.expo/

# EAS build artifacts
*.eas-build-local.json
eas-build-local.json

# Expo web build
web-build/
frontend/web-build/

# Expo generated types
expo-env.d.ts

# Generated native folders (Expo prebuild/eject)
ios/
android/
frontend/ios/
frontend/android/

# Metro bundler
.metro-health-check*

# React Native cache
.haste_map.fb.js

# Kotlin build
.kotlin/

# Code signing (iOS/Android)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore
*.orig.*
*.provisionprofile

# ===========================================
# Backend / Prisma
# ===========================================

# Prisma generated client (regenerated on install)
backend/node_modules/.prisma/

# SQLite (if used for local dev)
*.db
*.db-journal
prisma/*.db
prisma/*.db-journal

# ===========================================
# Docker
# ===========================================
docker-data/
postgres-data/
redis-data/

# ===========================================
# Testing
# ===========================================
coverage/
.nyc_output/
*.lcov
.jest/
__snapshots__/

# ===========================================
# AWS / Cloud
# ===========================================
.aws/
.serverless/

# ===========================================
# Security / Secrets
# ===========================================
*.pem
*.secret
secrets/
*.cert
*.crt
ssl/

# ===========================================
# Misc
# ===========================================
.cache/
.turbo/
*.tmp
*.temp
temp/
uploads/

# Process/lock files
*.pid
*.seed
*.pid.lock

# Debug
.fusebox/
.dynamodb/

# Parcel (if used)
.parcel-cache/

# Backup files
*.bak
*.backup
*~
*.seed

# Optional npm cache
.npm/

# ESLint cache
.eslintcache

# Prettier cache
.prettierignore

# Debug
.node_repl_history

# AI files
CLAUDE.md

